{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "noEmit": false,
    "outDir": "dist",
    "types": ["node"],
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "server.ts",
    "tier.ts",
    "db.ts",
    "image.ts",
    "pattern.ts",
    "get.ts",
    "list_recent.ts",
    "search.ts",
    "set_title.ts",
    "forget.ts",
    "add_item.ts",
    "telemetry.ts"
  ],
  "exclude": ["test_*.mjs", "dist", "node_modules"]
}
