{
  "name": "maus-mcp",
  "version": "1.0.5",
  "description": "MCP server exposing the Maus clipboard manager (mausformac.com) to Claude Code, Cursor, Codex and other MCP clients. Local-only, tier-aware.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "maus-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/server.js",
    "dev": "tsx server.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "clipboard",
    "claude",
    "claude-code",
    "cursor",
    "codex",
    "maus",
    "macos"
  ],
  "author": "Manuel Toledo <manu@mausformac.com>",
  "license": "MIT",
  "homepage": "https://github.com/mnlt/maus-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnlt/maus-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mnlt/maus-mcp/issues"
  },
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
